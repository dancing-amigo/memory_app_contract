{
  "method": "POST",
  "path": "/v1/app-bindings/bootstrap",
  "headers": {
    "Authorization": "Bearer mem_app_live_example.secret",
    "X-Memory-On-Behalf-Of-Type": "user",
    "X-Memory-On-Behalf-Of-Id": "user_001",
    "Idempotency-Key": "google-workspace:drive-folder:folder_team_knowledge"
  },
  "body": {
    "app_resource": {
      "type": "google_drive_folder",
      "id": "folder_team_knowledge",
      "display_name": "Team Knowledge",
      "source_uri": "google-drive://folders/folder_team_knowledge"
    },
    "memory_space": {
      "id": "space_google_drive_folder_team_knowledge",
      "name": "Team Knowledge Drive",
      "owner": { "type": "team", "id": "team_001" },
      "memory_pack_id": "company_agent_v1",
      "storage_binding_id": "storage_google_drive_folder_team_knowledge",
      "policy_profile_id": "team_private_memory_v1",
      "model_profile_id": "default_ja_memory_v1"
    },
    "memberships": [
      {
        "principal": { "type": "user", "id": "user_001" },
        "permissions": ["read", "write", "admin"]
      }
    ],
    "source": {
      "id": "src_google_drive_files",
      "source_type": "google_drive_file",
      "display_name": "Google Drive files",
      "trust_zone": 3,
      "source_authority": "team_drive_document",
      "allowed_memory_writes": ["observation", "decision", "open_loop", "preference_evidence"],
      "disallowed_memory_writes": ["policy", "procedure"],
      "default_allowed_uses": ["search", "answer_generation", "reflection", "project_context", "company_policy_lookup"],
      "default_disallowed_uses": ["training", "external_share", "auto_action", "profile_update"],
      "default_sensitivity": "normal",
      "retention_policy": "default"
    }
  }
}
