{
  "method": "POST",
  "path": "/v1/app-bindings/bootstrap",
  "headers": {
    "Authorization": "Bearer mem_app_live_example.secret",
    "X-Memory-On-Behalf-Of-Type": "user",
    "X-Memory-On-Behalf-Of-Id": "user_001",
    "Idempotency-Key": "example:project:project_001"
  },
  "body": {
    "app_resource": {
      "type": "project",
      "id": "project_001",
      "display_name": "プロジェクト計画",
      "source_uri": "example://projects/project_001",
      "metadata": {
        "workspace_id": "workspace_001"
      }
    },
    "memory_space": {
      "id": "space_project_001",
      "name": "プロジェクト計画",
      "owner": {
        "type": "team",
        "id": "team_001"
      },
      "memory_pack_id": "company_agent_v1",
      "storage_binding_id": "storage_team_001",
      "policy_profile_id": "team_private_memory_v1",
      "model_profile_id": "default_ja_memory_v1"
    },
    "source": {
      "id": "src_app_segments",
      "source_type": "app_text_segment",
      "display_name": "アプリのテキスト segment",
      "trust_zone": 1,
      "source_authority": "user_utterance",
      "allowed_memory_writes": ["observation", "decision", "open_loop", "preference_evidence"],
      "disallowed_memory_writes": ["user_profile", "user_preference", "policy", "procedure"],
      "default_allowed_uses": ["search", "answer_generation", "reflection", "project_context"],
      "default_disallowed_uses": ["training", "external_share", "auto_action"],
      "default_sensitivity": "normal",
      "retention_policy": "default"
    }
  },
  "response": {
    "app_binding": {
      "id": "bind_example_project_001",
      "app_id": "example_app",
      "app_resource": {
        "type": "project",
        "id": "project_001"
      },
      "memory_principal": {
        "type": "team",
        "id": "team_001"
      },
      "memory_resource": {
        "type": "memory_space",
        "id": "space_project_001"
      },
      "source_id": "src_app_segments",
      "status": "active"
    },
    "memory_space": {
      "id": "space_project_001",
      "owner": {
        "type": "team",
        "id": "team_001"
      },
      "status": "active"
    },
    "source": {
      "id": "src_app_segments",
      "source_type": "app_text_segment",
      "status": "active"
    }
  }
}
